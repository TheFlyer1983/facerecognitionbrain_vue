$font-base-size: 16px;
$font-primary: Avenir, Helvetica, Arial, sans-serif;

body {
  --black-80: #{rgba(#000000, 0.8)};
  --black-10: #{rgba(#000000, 0.1)};
  --light-purple: #a463f2;

  --spacing-none: 0;
  --spacing-extra-small: 0.25rem;
  --spacing-small: 0.5rem;
  --spacing-medium: 1rem;
  --spacing-large: 2rem;
  --spacing-extra-large: 4rem;
  --spacing-extra-extra-large: 8rem;
  --spacing-extra-extra-extra-large: 16rem;
}
